generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?
  image         String?
  plan          String   @default("free") // "free" or "premium"
  credits       Float    @default(0)      // For premium users
  totalSpent    Float    @default(0)      // Total USD spent
  apiKeys       String?                  // JSON string for provider API keys
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chatSessions  ChatSession[]
  payments      Payment[]
  usageRecords  UsageRecord[]
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Chat")
  model     String   @default("nvidia/llama-3.1-8b-instruct")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id            String   @id @default(cuid())
  sessionId     String
  role          String   // "user", "assistant", "system"
  content       String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  cachedTokens  Int      @default(0)
  model         String?
  createdAt     DateTime @default(now())

  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id            String   @id @default(cuid())
  userId        String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  cachedTokens  Int      @default(0)
  creditsUsed   Float    @default(0)
  costUsd       Float    @default(0)
  model         String
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  razorpayOrderId     String?
  razorpayPaymentId   String?
  amount        Float              // Amount in USD
  creditsAdded  Float
  status        String   @default("pending") // "pending", "completed", "failed"
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
